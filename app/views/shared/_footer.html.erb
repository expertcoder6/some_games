<footer class="site-footer">
  <div class="site-footer__main">
    <a class="site-footer__brand" href="#">
      <%= image_tag "brand/logo.svg", alt: "Turnip cake", class: "site-footer__brand-icon" %>
    </a>

    <div class="site-footer-bottom">
      <div class="footer-cube" aria-hidden="true">
        <%= image_tag "brand/cube.png", alt: "", class: "footer-cube__image" %>
      </div>
      <a class="btn btn-events" href="#">Find events near you</a>

      <div class="site-footer__social">
        <a href="#" aria-label="Facebook" class="site-footer__social-link">
          <%= image_tag "brand/facebook.svg", alt: "Facebook", class: "site-footer__social-icon" %>
        </a>
        <a href="#" aria-label="Instagram" class="site-footer__social-link">
          <%= image_tag "brand/instagram.svg", alt: "Instagram", class: "site-footer__social-icon" %>
        </a>
        <a href="#" aria-label="X" class="site-footer__social-link">
          <%= image_tag "brand/x.svg", alt: "X", class: "site-footer__social-icon" %>
        </a>
      </div>
    </div>

    <nav class="site-footer__links" aria-label="Footer">
      <a href="#">About</a>
      <a href="#">Support</a>
      <a href="#">Privacy Policy</a>
    </nav>
  </div>
</footer>
